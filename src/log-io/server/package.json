{
  "name": "log.io",
  "version": "0.5.0",
  "description": "Listens for new messages over TCP and broadcasts to browsers via socket.io",
  "homepage": "http://logio.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/NarrativeScience/log.io.git"
  },
  "keywords": [
    "logs",
    "monitoring",
    "realtime",
    "socket.io",
    "node.js"
  ],
  "author": "msmathers@narrativescience.com",
  "main": "lib/index.js",
  "scripts": {
    "type-check": "tsc --noEmit",
    "type-check:watch": "npm run type-check -- --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "build": "tsc",
    "start": "node lib/index.js",
    "build:ui": "node ./bin/build-ui.mjs",
    "prepare": "npm run build && node ./bin/build-ui.mjs"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "bin": {
    "log.io-server": "./bin/log.io-server"
  },
  "dependencies": {
    "express": "^5.1.0",
    "express-basic-auth": "^1.2.1",
    "socket.io": "^4.8.1"
  }
}

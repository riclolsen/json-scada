  <!--
    Post-Build:
    Copy compiled ServerPlugin.dll next to OpcNetDaServer*.exe in the bin\ folder.
    Adjust the source path to match the Technosoftware generic server EXE location.
  -->
  <PropertyGroup>
    <PostBuildEvent>
      ECHO [PostBuild] Platform: $(Platform)
      ECHO [PostBuild] Configuration: $(Configuration)
      ECHO [PostBuild] TargetDir: $(TargetDir)
      ECHO [PostBuild] SolutionDir: $(SolutionDir)
      IF EXIST "$(TargetDir)ServerPlugin.dll" (
        IF NOT EXIST "$(SolutionDir)bin\$(Platform)\$(Configuration)" mkdir "$(SolutionDir)bin\$(Platform)\$(Configuration)"
        COPY /Y "$(TargetDir)*.dll" "$(SolutionDir)bin\$(Platform)\$(Configuration)"
        IF EXIST "$(TargetDir)ServerPlugin.dll.config" (
          COPY /Y "$(TargetDir)ServerPlugin.dll.config" "$(SolutionDir)bin\$(Platform)\$(Configuration)\OpcNetDaServer.exe.config"
        )
      )
      EXIT 0
    </PostBuildEvent>
  </PropertyGroup>

